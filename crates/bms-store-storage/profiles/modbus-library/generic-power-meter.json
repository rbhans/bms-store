{
  "profile": {
    "id": "generic-power-meter",
    "name": "Generic Power Meter",
    "type": "generic",
    "version": "1.0.0",
    "description": "Common Modbus power meter registers (voltage, current, power, energy). Compatible with most power meters using IEEE float registers.",
    "manufacturer": null,
    "model": null,
    "tags": ["power", "meter", "electrical"]
  },
  "defaults": {
    "protocols": {
      "modbus": {
        "unit_id": 1,
        "response_timeout_ms": 5000,
        "retry_count": 3
      }
    }
  },
  "points": [
    {
      "id": "voltage-l1",
      "name": "Voltage L1",
      "description": "Line 1 voltage",
      "kind": "analog",
      "access": "input",
      "units": "V",
      "protocols": {
        "modbus": {
          "register_type": "holding",
          "address": 0,
          "data_type": "float32",
          "scale": 1.0,
          "register_count": 2
        }
      }
    },
    {
